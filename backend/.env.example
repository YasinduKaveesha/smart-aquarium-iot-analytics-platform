# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=aquarium

# MQTT
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_TOPIC=aquarium/telemetry
MQTT_CLIENT_ID=aquaguard-backend

# System — set to the date the tank was installed (YYYY-MM-DD)
# For demo: use 2026-01-01 so the tank is 70+ days old and ADAPTIVE mode is always active
INSTALL_DATE=2026-01-01

# Gemini — conversational AI agent
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Frontend origins allowed by CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
